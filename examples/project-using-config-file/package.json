{
  "name": "project-using-config-file",
  "version": "1.0.0",
  "description": "Example project using npmdata via a local configuration file (package.json 'npmdata' key or .npmdatarc)",
  "dependencies": {
    "example-files-package": "file:../dist/example-files-package-1.0.0.tgz",
    "npmdata": "file:../lib/dist/npmdata-0.0.1.tgz"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748",
  "npmdata": {
    "postExtractScript": "node myPostExtract.js",
    "sets": [
      {
        "package": "example-files-package",
        "upgrade": false,
        "selector": {
          "files": [
            "docs/**",
            "data/**"
          ],
          "contentRegexes": [
            ".*"
          ]
        },
        "output": {
          "path": "output",
          "force": false,
          "keepExisting": true,
          "gitignore": true,
          "unmanaged": false,
          "dryRun": false,
          "symlinks": [
            {
              "source": "data/**",
              "target": "data-symlink/"
            }
          ],
          "contentReplacements": [
            {
              "files": "docs/**",
              "match": "exampleTODOTESTCHECKLATER",
              "replace": "sample"
            }
          ]
        },
        "presets": [
          "basic"
        ]
      },
      {
        "package": "eslint@8",
        "selector": {
          "files": [
            "conf/globals.js"
          ]
        },
        "output": {
          "path": "output/eslint",
          "unmanaged": true
        },
        "presets": [
          "extra"
        ]
      }
    ]
  }
}
